{
  "name": "bridgecast-desktop",
  "version": "1.0.0",
  "description": "BridgeCast Desktop — Audio/Video streaming bridge",
  "main": "main.js",
  "scripts": {
    "start":          "electron .",
    "start:dev":      "ELECTRON_DEV=1 electron .",
    "pack":           "electron-builder --dir",
    "dist:win":       "electron-builder --win --x64",
    "dist:win:port":  "electron-builder --win portable --x64",
    "dist:linux":     "electron-builder --linux --x64",
    "dist:mac":       "electron-builder --mac --x64"
  },
  "build": {
    "appId": "com.bridgecast.desktop",
    "productName": "BridgeCast",
    "copyright": "BridgeCast",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../server/target/release/server",
        "to":   "bin/server",
        "filter": ["**/*"]
      },
      {
        "from": "../server/target/release/server.exe",
        "to":   "bin/server.exe",
        "filter": ["**/*"]
      },
      {
        "from": "../server/static",
        "to":   "static"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick":            false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":        "BridgeCast"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
